{
  "buildCommand": "cd dashboard && npm install && npm run build",
  "outputDirectory": "dashboard/dist",
  "functions": {
    "api/enrich.js": {
      "memory": 256,
      "maxDuration": 60
    },
    "api/profile.js": {
      "memory": 256,
      "maxDuration": 120
    },
    "api/cred-review.js": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
